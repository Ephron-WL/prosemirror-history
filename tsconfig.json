{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",
		"declaration": true,
		"declarationMap": false,
		"sourceMap": true,
		"inlineSources": true,
		"strict": false,
		"noImplicitOverride": false,
		"noImplicitReturns": false,
		"noPropertyAccessFromIndexSignature": false
	},
	"include": [
		"src/**/*.ts"
	]
}
